# ============================================================
# ToolForge Environment Variables Configuration
# 使用方法：复制此文件为 .env，填写真实值后加载
# Usage:  Copy this file to .env, fill in your values, then run:
#         export $(grep -v '^#' .env | xargs)
# ============================================================

# ------------------------------------------------------------
# API Keys (comma-separated list, all keys will be rotated)
# 格式：多个 key 用英文逗号分隔，程序会自动轮换
# ------------------------------------------------------------
API_KEYS=sk-your-key-1,sk-your-key-2,sk-your-key-3

# ------------------------------------------------------------
# API Base URL
# OpenAI:    https://api.openai.com/v1
# Azure:     https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
# Local/vLLM: http://localhost:8000/v1
# Other compatible API providers: change accordingly
# ------------------------------------------------------------
API_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------
# Model names used in each stage
# Stage 1/2/3 Generation Model
# ------------------------------------------------------------
DEFAULT_MODEL=gpt-4.1

# Stage 4 Judge Model (used for quality scoring)
JUDGE_MODEL=gpt-4.1

# ------------------------------------------------------------
# SentenceTransformer model path (used in Stage 1 for deduplication)
# Download bge-m3 model first: python -c "from huggingface_hub import snapshot_download; snapshot_download('BAAI/bge-m3', local_dir='./models/bge-m3')"
# ------------------------------------------------------------
SENTENCE_TRANSFORMER_MODEL_PATH=./models/bge-m3

# ------------------------------------------------------------
# Stage 2 file paths (optional, defaults shown below)
# INPUT_FILE:   path to the input .jsonl file for Stage 2
# OUTPUT_FILE:  path to save labeled results
# RESIDUE_FILE: path to save unprocessed/overflow records
# ------------------------------------------------------------
INPUT_FILE=Stage_2/original_data/HotpotQA/bridge_hp.jsonl
OUTPUT_FILE=Stage_2/label_data/output.jsonl
RESIDUE_FILE=Stage_2/label_data/residue.jsonl
